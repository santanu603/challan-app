<!DOCTYPE html>
<html>
<head>
<title>Counters</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">

<style>
body { font-family:Poppins; background:#0b1120; color:white; margin:0; }
.main { margin-left:240px; padding:30px; }

table {
    width:100%;
    border-collapse: collapse;
    margin-top:20px;
}

th, td {
    padding:12px;
    text-align:center;
    border: #026433 solid 1px;
}


th { background:#1f2937; }

tr:hover { background:#1a2438; }

.edit {
    background: #3b82f6;
    padding: 6px 10px;
    border-radius: 5px;
    color: white;
    text-decoration: none;
    margin-right: 5px;
}

.delete {
    background: #ef4444;
    padding: 6px 10px;
    border-radius: 5px;
    color: white;
    text-decoration: none;
}

</style>
</head>

<body>

<%- include("partials/sidebar") %>

<div class="main">

<h2>🏢 Counters List</h2>

<table>
<tr>
    <th>Name</th>
    <th>Address</th>
    <th>Phone</th>
    <th>Action</th>
</tr>

<% counters.forEach(c => { %>
<tr>
    <td><%= c.name %></td>
    <td><%= c.address %></td>
    <td><%= c.phone %></td>
    <td>
        <a href="/counter/edit/<%= c._id %>" class="edit">Edit</a>
        <a href="/counter/delete/<%= c._id %>" class="delete" onclick="return confirm('Delete this counter?')">Delete</a>
    </td>
</tr>
<% }) %>

</table>

</div>

</body>
</html>