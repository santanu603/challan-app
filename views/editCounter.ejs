<!DOCTYPE html>
<html>
<head>
<title>Edit Counter</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">
<style>
body { font-family:Poppins; background:#0b1120; color:white; }
.main { margin-left:240px; padding:30px; }

input {
    padding:10px;
    margin:10px 0;
    width:300px;
    border-radius:6px;
    border:none;
    background-color: #1f2937;
    color:#0f9954;
    font-weight: bold;
}

button {
    padding:10px;
    background:#22c55e;
    border:none;
    color:white;
    border-radius:6px;
}
</style>
</head>

<body>

<%- include("partials/sidebar") %>

<div class="main">

<h2>Edit Counter</h2>

<form method="POST" action="/counter/update/<%= counter._id %>">

<input type="text" name="name" value="<%= counter.name %>" required>
<input type="text" name="address" value="<%= counter.address %>">
<input type="text" name="phone" value="<%= counter.phone %>">

<br>
<button>Update</button>

</form>

</div>

</body>
</html>