<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
<style>
body {
    font-size: 12px;
}

.header {
    text-align: center;
    margin-bottom: 6px;
}

.logo {
    height: 50px;
}

.company-name {
    font-size: 16px;
    font-weight: bold;
}

.company-details {
    font-size: 11px;
}

.info {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
    font-size: 12px;
}

.section {
    margin-top: 6px;
    font-size: 12px;
}

table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 8px;
    font-size: 12px;
}

th, td {
    border: 1px solid #000;
    padding: 4px;
    text-align: center;
}

.total {
    text-align: right;
    margin-top: 4px;
    font-weight: bold;
    font-size: 12px;
}

.footer {
    display: flex;
    justify-content: space-between;
    margin-top: 20px;
    font-size: 12px;
}

.sign {
    text-align: center;
    width: 180px;
}
</style>

<body>
    

<!-- HEADER -->
<div class="header">
    <% if (company.logo) { %>
        <img src="<%= company.logo %>" class="logo">
    <% } %>

    <div class="company-name"><%= company.name %></div>
    <div class="company-details">
        <%= company.address %><br>
        📞 <%= company.phone %> | ✉ <%= company.email %>
    </div>
</div>

<hr>

<!-- INFO -->
<div class="info">
    <div>
        <b>Challan No:</b> <%= challan.challanNumber %><br>
        <b>Date:</b> <%= new Date(challan.date).toLocaleDateString() %>
        <svg id="barcode"></svg>
    </div>

    <div>
        Counter: <b><%= challan.counterName %></b><br>
        Address: <%= challan.counterAddress || "N/A" %><br>
        Phone: <b><%= challan.counterPhone || "N/A" %></b>
    </div>
</div>

<!-- TABLE -->
<table>
<tr>
    <th>Sl No</th>
    <th>Item</th>
    <th>Qty</th>
    <th>Price</th>
    <th>Total</th>
</tr>

<%
let totalQty = 0;
challan.items.forEach((item, index) => {
    totalQty += item.quantity;
%>

<tr>
    <td><%= index + 1 %></td>
    <td><%= item.name %></td>
    <td><%= item.quantity %></td>
    <td>₹ <%= item.price %></td>
    <td>₹ <%= item.quantity * item.price %></td>
</tr>

<% }) %>

</table>

<div class="total">
    Total Qty: <%= totalQty %> |
    Total Amount: ₹ <%= challan.totalAmount %>
</div>

<!-- REMARKS -->
<% if (challan.remarks) { %>
<div class="section">
    <b>Remarks:</b> <%= challan.remarks %>
</div>
<% } %>

<!-- SIGNATURE -->
<div class="footer">
    <div class="sign">
        ___________________<br>
        Receiver Signature
    </div>

    <div class="sign">
        ___________________<br>
        Authorized Signatory
    </div>
</div>

<script>
    window.onload = function () {
        JsBarcode("#barcode", "<%= challan.challanNumber %>", {
            format: "CODE128",
            lineColor: "#000",
            width: 1.5,
            height: 40,
            displayValue: false
        });
    };
    
</script>
