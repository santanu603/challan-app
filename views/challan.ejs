<!DOCTYPE html>
<html>
<head>
    <title>Challan</title>

    <style>
        body {
            font-family: Arial;
            background: #f3f4f6;
            margin: 0;
            padding: 20px;
        }

        .page {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .receipt {
            background: #fff;
            padding: 15px;
            border: 1px solid #ccc;
        }

        .label {
            text-align: left;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .print-btn {
            margin-bottom: 15px;
            padding: 10px 15px;
            background: #22c55e;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }

        @media print {
            .print-btn {
                display: none;
            }

            .back-btn {
                display: none;
            }

            body {
                background: white;
            }

            .receipt {
                page-break-inside: avoid;
            }
        }

        .top-actions{
    display:flex;
    justify-content:space-between;
    margin-bottom:15px;
}

.back-btn{
    background:#3b82f6;
    color:white;
    padding:10px 15px;
    border-radius:6px;
    text-decoration:none;
    font-size:14px;
}

.back-btn:hover{
    background:#2563eb;
}


.print-btn{
    padding:10px 15px;
    background:#22c55e;
    color:white;
    border:none;
    border-radius:6px;
    cursor:pointer;
    font-size:14px;
}

.print-btn:hover{
    background:#16a34a;
}
    </style>
</head>

<body>

<div class="top-actions">

    <a href="/" class="back-btn">
        ⬅ Dashboard
    </a>
    

    <button onclick="window.print()" class="print-btn">
        🖨 Print
    </button>

</div>

<div class="page">

    <!-- ORIGINAL -->
    <div class="receipt">
        <div class="label">ORIGINAL RECEIPT</div>
        <%- include("partials/challanBody", { challan, company }) %>
    </div>

    <!-- DUPLICATE -->
    <div class="receipt">
        <div class="label">DUPLICATE RECEIPT</div>
        <%- include("partials/challanBody", { challan, company }) %>
    </div>

</div>

</body>
</html>